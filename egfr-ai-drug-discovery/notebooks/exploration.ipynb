"source": [
"# 🧬 EGFR AI Drug Discovery – Exploration Notebook\n",
"\n",
"This notebook explores:\n",
"- SMILES data\n",
"- SELFIES conversion\n",
"- Molecular properties\n",
"- Molecule generation\n",
"- Scoring and optimization\n"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"import pandas as pd\n",
"import numpy as np\n",
"import matplotlib.pyplot as plt\n",
"\n",
"from rdkit import Chem\n",
"from rdkit.Chem import Descriptors, Draw\n",
"\n",
"import selfies as sf\n",
"import random\n",
"\n",
"from src.preprocessing import smiles_to_selfies, selfies_to_smiles\n",
"from src.reward import reward\n",
"from src.rl import optimize\n",
"from src.utils import validate\n",
"\n",
"print("✅ Libraries loaded")"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 📂 Load Dataset"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"data = pd.read_csv("../data/egfr_smiles.csv")\n",
"smiles_list = data["smiles"].dropna().tolist()\n",
"\n",
"print("Total molecules:", len(smiles_list))\n",
"smiles_list[:10]"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🧪 Validation"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"valid_smiles = [s for s in smiles_list if validate(s)]\n",
"\n",
"print("Valid:", len(valid_smiles))\n",
"print("Invalid:", len(smiles_list) - len(valid_smiles))"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🔄 SMILES → SELFIES"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"selfies_list = smiles_to_selfies(valid_smiles)\n",
"selfies_list[:5]"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🔁 SELFIES → SMILES"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"reconstructed = selfies_to_smiles(selfies_list)\n",
"reconstructed[:5]"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🧬 Molecular Properties"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"mw, logp = [], []\n",
"\n",
"for smi in valid_smiles:\n",
"    mol = Chem.MolFromSmiles(smi)\n",
"    if mol:\n",
"        mw.append(Descriptors.MolWt(mol))\n",
"        logp.append(Descriptors.MolLogP(mol))\n",
"\n",
"print("Computed properties")"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 📊 Visualization"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"plt.hist(mw, bins=30)\n",
"plt.title("Molecular Weight")\n",
"plt.show()"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"plt.hist(logp, bins=30)\n",
"plt.title("LogP")\n",
"plt.show()"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🧪 Molecule Visualization"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"mols = [Chem.MolFromSmiles(s) for s in valid_smiles[:9]]\n",
"Draw.MolsToGridImage(mols)"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## ⚙️ Mock Generation"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"def generate_variants(smiles_list, n=3):\n",
"    generated = []\n",
"    for smi in smiles_list:\n",
"        for _ in range(n):\n",
"            mutated = ''.join(random.sample(smi, len(smi)))\n",
"            generated.append(mutated)\n",
"    return generated\n",
"\n",
"generated = generate_variants(valid_smiles[:20], 5)\n",
"len(generated)"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🧪 Validate Generated"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"valid_generated = [s for s in generated if validate(s)]\n",
"len(valid_generated)"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🎯 Scoring"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"scored = [(s, reward(s)) for s in valid_generated]\n",
"scored = sorted(scored, key=lambda x: -x[1])\n",
"scored[:10]"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 🔄 Optimization"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"optimized = optimize(valid_generated)\n",
"optimized[:10]"
]
},
{
"cell_type": "markdown",
"metadata": {},
"source": [
"## 📌 Summary"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {},
"outputs": [],
"source": [
"print("Initial:", len(smiles_list))\n",
"print("Valid:", len(valid_smiles))\n",
"print("Generated:", len(generated))\n",
"print("Valid Generated:", len(valid_generated))"
]
}
